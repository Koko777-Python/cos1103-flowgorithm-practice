<?xml version="1.0"?>
<flowgorithm fileversion="4.2">
    <attributes>
        <attribute name="name" value="EX loop &#3619;&#3633;&#3610;&#3588;&#3656;&#3634;&#3629;&#3634;&#3618;&#3640;"/>
        <attribute name="authors" value="Koko777-Python"/>
        <attribute name="about" value=""/>
    </attributes>
    <function name="Main" type="None" variable="">
        <parameters/>
        <body>
            <declare name="age" type="Integer" array="False" size=""/>
            <do expression="age&lt;1 or age&gt;120">
                <output expression="&quot;กรอกอายุ (1-120 ปี)&quot;" newline="True"/>
                <input variable="age"/>
            </do>
            <output expression="&quot;อายุ = &quot; &amp; age &amp; &quot; ปี&quot;" newline="True"/>
        </body>
    </function>
</flowgorithm>
