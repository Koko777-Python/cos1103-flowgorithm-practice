    <function name="Main" type="None" variable="">
        <parameters/>
        <body>
            <declare name="temperature" type="Integer" array="False" size=""/>
            <do expression="temperature&lt; -40 or temperature&gt; 60">
                <output expression="&quot;&#3585;&#3619;&#3629;&#3585;&#3629;&#3640;&#3603;&#3627;&#3616;&#3641;&#3617;&#3636; (-40 - 60)&quot;" newline="True"/>
                <input variable="temperature"/>
            </do>
            <output expression="&quot;&#3629;&#3640;&#3603;&#3627;&#3616;&#3641;&#3617;&#3636; = &quot;&amp;temperature&amp;&quot;  &#3629;&#3591;&#3624;&#3634;&quot;" newline="True"/>
        </body>
    </function>
</flowgorithm>
