<?xml version="1.0"?>
<flowgorithm fileversion="4.2">
    <attributes>
        <attribute name="name" value="EX loop &#3626;&#3636;&#3609;&#3588;&#3657;&#3634;&#3621;&#3604;&#3619;&#3634;&#3588;&#3634; 10%"/>
        <attribute name="authors" value="VICTUS GAMING 16"/>
        <attribute name="about" value=""/>
        <attribute name="saved" value="2026-07-17 09:06:13 PM"/>
        <attribute name="created" value="VklDVFVTIEdBTUlORyAxNjtERVNLVE9QLTFDS0EzSzc7MjAyNi0wNy0xNzswODo0NzoyOCBQTTszMzk4"/>
        <attribute name="edited" value="VklDVFVTIEdBTUlORyAxNjtERVNLVE9QLTFDS0EzSzc7MjAyNi0wNy0xNzswOTowNjoxMyBQTTsxOzM0OTY="/>
    </attributes>
    <function name="Main" type="None" variable="">
        <parameters/>
        <body>
            <declare name="price, discount, netprice" type="Real" array="False" size=""/>
            <do expression="price&lt;100 or price&gt;1000">
                <output expression="&quot;&#3585;&#3619;&#3629;&#3585;&#3619;&#3634;&#3588;&#3634;&#3626;&#3636;&#3609;&#3588;&#3657;&#3634; (100-1000)&quot;" newline="True"/>
                <input variable="price"/>
            </do>
            <assign variable="discount" expression="price*10/100"/>
            <assign variable="netprice" expression="price-discount"/>
            <output expression="&quot;&#3619;&#3634;&#3588;&#3634;&#3626;&#3636;&#3609;&#3588;&#3657;&#3634; =&quot; &amp;price &amp;&quot;&#3610;&#3634;&#3607;&quot;" newline="True"/>
            <output expression="&quot;&#3626;&#3656;&#3623;&#3609;&#3621;&#3604; 10% = &quot;&amp;discount&amp;&quot;&#3610;&#3634;&#3607;&quot;" newline="True"/>
            <output expression="&quot;&#3619;&#3634;&#3588;&#3634;&#3627;&#3621;&#3633;&#3591;&#3627;&#3633;&#3585;&#3626;&#3656;&#3623;&#3609;&#3621;&#3604; = &quot;&amp;netprice&amp;&quot;&#3610;&#3634;&#3607;&quot;" newline="True"/>
        </body>
    </function>
</flowgorithm>
