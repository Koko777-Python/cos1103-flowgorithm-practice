    <function name="Main" type="None" variable="">
        <parameters/>
        <body>
            <declare name="minscore, maxscore" type="Real" array="False" size=""/>
            <do expression="minscore&lt;0 or minscore&gt;100">
                <output expression="&quot;&#3585;&#3619;&#3629;&#3585;&#3588;&#3632;&#3649;&#3609;&#3609;&#3605;&#3656;&#3635;&#3626;&#3640;&#3604; (0-100)&quot;" newline="True"/>
                <input variable="minscore"/>
            </do>
            <do expression="maxscore&lt;minscore or maxscore&gt;100">
                <output expression="&quot;&#3585;&#3619;&#3629;&#3585;&#3588;&#3632;&#3649;&#3609;&#3609;&#3626;&#3641;&#3591;&#3626;&#3640;&#3604; &#3650;&#3604;&#3618;&#3605;&#3657;&#3629;&#3591;&#3617;&#3634;&#3585;&#3585;&#3623;&#3656;&#3634;&#3627;&#3619;&#3639;&#3629;&#3648;&#3607;&#3656;&#3634;&#3585;&#3633;&#3610;&#3588;&#3632;&#3649;&#3609;&#3609;&#3605;&#3656;&#3635;&#3626;&#3640;&#3604;&#3649;&#3621;&#3632;&#3652;&#3617;&#3656;&#3648;&#3585;&#3636;&#3609; 100 &quot;" newline="True"/>
                <input variable="maxscore"/>
            </do>
            <output expression="&quot;&#3588;&#3632;&#3649;&#3609;&#3609;&#3605;&#3656;&#3635;&#3626;&#3640;&#3604; = &quot;&amp;minscore&amp;&quot;  &#3588;&#3632;&#3649;&#3609;&#3609;&quot;" newline="True"/>
            <output expression="&quot;&#3588;&#3632;&#3649;&#3609;&#3609;&#3626;&#3641;&#3591;&#3626;&#3640;&#3604; = &quot;&amp;maxscore&amp;&quot;  &#3588;&#3632;&#3649;&#3609;&#3609;&quot;" newline="True"/>
        </body>
    </function>
</flowgorithm>
