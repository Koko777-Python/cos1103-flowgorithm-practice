    <attributes>
        <attribute name="name" value="EX loop &#3588;&#3632;&#3649;&#3609;&#3609;&#3605;&#3656;&#3635;&#3626;&#3640;&#3604;&#3649;&#3621;&#3632;&#3588;&#3632;&#3649;&#3609;&#3609;&#3626;&#3641;&#3591;&#3626;&#3640;&#3604;"/>
